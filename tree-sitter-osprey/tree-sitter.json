{
  "grammars": [
    {
      "name": "osprey",
      "camelcase": "Osprey",
      "scope": "source.osprey",
      "path": ".",
      "file-types": [
        "osp"
      ],
      "highlights": [
        "queries/highlights.scm"
      ]
    }
  ],
  "metadata": {
    "version": "0.0.0-dev",
    "license": "MIT",
    "description": "Tree-sitter grammar for the Osprey language (single canonical grammar: compiler, LSP, highlighting)",
    "links": {
      "repository": "https://github.com/MelbourneDeveloper/osprey"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
