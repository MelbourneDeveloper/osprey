{
  "manifestVersion": 1,
  "product": {
    "id": "osprey",
    "displayName": "Osprey",
    "version": "0.0.0-dev",
    "repository": "https://github.com/Nimblesite/osprey",
    "homepage": "https://ospreylang.dev"
  },
  "components": [
    {
      "id": "osprey",
      "kind": "cli",
      "binaryName": "osprey",
      "expectedVersion": "0.0.0-dev",
      "platforms": ["darwin-arm64", "darwin-x64", "linux-x64", "win32-x64"],
      "sources": ["user-setting", "bundled", "path", "github-release", "pkgmgr"],
      "userSetting": "osprey.server.compilerPath",
      "bundled": {
        "bundlePath": "bin/${platform}/${binaryName}${exe}",
        "perPlatformArtifact": true
      },
      "pkgmgr": {
        "brew": "osprey",
        "scoop": "osprey"
      },
      "githubRelease": {
        "repo": "Nimblesite/osprey",
        "assetPattern": "osprey-${version}-${platform}.tar.gz",
        "checksum": true
      },
      "verifyStartup": true,
      "versionCheckStrategy": "version-flag",
      "required": true
    },
    {
      "id": "osprey-vscode",
      "kind": "extension-vscode",
      "language": "typescript",
      "expectedVersion": "0.0.0-dev",
      "platforms": ["darwin-arm64", "darwin-x64", "linux-x64", "win32-x64"],
      "required": true
    }
  ],
  "hosts": {
    "vscode": {
      "artifact": "vsix-per-platform",
      "activationVerifies": ["osprey"],
      "onMismatch": "prompt-reinstall"
    },
    "cli": {
      "artifact": "archive",
      "activationVerifies": ["osprey"],
      "onMismatch": "error"
    },
    "pkgmgr": {
      "artifact": "brew-formula",
      "activationVerifies": ["osprey"],
      "onMismatch": "error"
    }
  }
}
