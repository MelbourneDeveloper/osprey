// PostgreSQL through the SAME generic FFI as SQLite — proof that the Database
// layer is engine-agnostic. libpq is just another C library bound with extern fn
// and linked with `// @link:`. No new compiler work over the SQLite path.
//
// This is a link/bind smoke test (PQlibVersion needs no server). A full
// connect + query demo binds PQconnectdb / PQexecParams / PQgetvalue / PQfinish
// the same way and requires a running PostgreSQL instance.
//
// NOTE: not in examples/tested/ because the library search path is
// platform-specific. On macOS, Homebrew's libpq is keg-only, hence the
// `// @linkdir:` below; on Linux, `libpq-dev` installs to a standard path and
// the `@linkdir` line is unnecessary. Adjust the path for your machine.
//
// @link: pq
// @linkdir: /opt/homebrew/opt/libpq/lib

extern fn PQlibVersion() -> int

fn status(v: int) -> string = match v > 0 {
    true => "pg linked ok"
    false => "pg link fail"
}

print(status(v: PQlibVersion()))
