// ============================================================================
//  Osprey stateful HTTP server — STATE AT EVERY LEVEL OF THE API, via
//  algebraic effects. Run it, then point the TUI client at it:
//
//      osprey examples/statefulhttp/server.osp --run      # terminal 1
//      osprey examples/statefulhttp/tui.osp --run         # terminal 2
//
//  The request handler is PURE: it only `perform`s. All mutable state lives in
//  the effect handlers installed by `main`, one per architectural layer:
//
//      Persist  (infrastructure)  owns the on-disk snapshot   — writes a file
//      Metrics  (server runtime)  owns the request counter     — bumped per call
//      Db       (application)     owns the task table           — the domain data
//
//  Handler-owned state is just a `mut` the handler closes over: `perform`
//  threads a value through it and the performer resumes — a real State effect.
//  The effects even cross the C HTTP-callback boundary: the server runs the
//  pure handler on its accept thread and the `perform`s resolve to these
//  handlers. Swap the handlers and the same routes run against a mock.
// ============================================================================

effect Db {
    add:   fn(string) -> int      // append a task, returns its id
    list:  fn() -> string         // the rendered task table
    count: fn() -> int            // how many tasks exist
}
effect Metrics {
    hit:    fn(string) -> Unit    // record one served request
    served: fn() -> int           // total requests served since boot
}
effect Persist {
    flush: fn(string) -> int      // durably write a snapshot, returns bytes
}
effect Log { info: fn(string) -> Unit }

// ---- ANSI pizazz (pure string wrappers) ------------------------------------
fn esc(code: string, s: string) -> string = "\e[${code}m${s}\e[0m"
fn c256(n: string, s: string) -> string = "\e[38;5;${n}m${s}\e[0m"   // 256-color foreground
fn bold(s: string) -> string = esc("1", s)
fn dim(s: string) -> string = esc("2", s)
fn cyan(s: string) -> string = esc("36", s)
fn green(s: string) -> string = esc("92", s)
fn yellow(s: string) -> string = esc("93", s)
fn magenta(s: string) -> string = esc("95", s)
fn inc(x: int) -> int = x + 1
fn mn(a: int, b: int) -> int = match a < b { true => a  false => b }

// A colored, fixed-width method badge (black text on a colored block).
fn badge(method: string) -> string = match method {
    "POST" => "\e[1;30;48;5;213m POST \e[0m"
    "GET"  => "\e[1;30;48;5;117m GET  \e[0m"
    _      => "\e[1;30;48;5;250m ${method} \e[0m"
}

// A bar of N filled blocks (capped) — a live gauge of how many tasks exist.
fn blocks(i: int, n: int) -> string = match i < n {
    true  => "▰" + blocks(inc(i), n)
    false => ""
}
fn gauge(n: int) -> string = c256("213", blocks(0, mn(n, 28)))

fn divider() -> string = c256("239", "  ──────────────────────────────────────────────────────")

// A six-line ASCII "OSPREY" with a cyan→magenta gradient (one color per row).
fn art() -> string =
    c256("51",  "   ██████╗ ███████╗██████╗ ██████╗ ███████╗██╗   ██╗") + "\n" +
    c256("45",  "  ██╔═══██╗██╔════╝██╔══██╗██╔══██╗██╔════╝╚██╗ ██╔╝") + "\n" +
    c256("39",  "  ██║   ██║███████╗██████╔╝██████╔╝█████╗   ╚████╔╝ ") + "\n" +
    c256("99",  "  ██║   ██║╚════██║██╔═══╝ ██╔══██╗██╔══╝    ╚██╔╝  ") + "\n" +
    c256("135", "  ╚██████╔╝███████║██║     ██║  ██║███████╗   ██║   ") + "\n" +
    c256("171", "   ╚═════╝ ╚══════╝╚═╝     ╚═╝  ╚═╝╚══════╝   ╚═╝   ")

// The whole startup banner as one string (one print, no consecutive prints).
fn banner() -> string =
    "\n" + art() + "\n\n  " +
    c256("46", "●") + dim(" live  ") + bold(c256("159", "http://127.0.0.1:8080")) +
    dim("   ·   state lives in algebraic-effect handlers") + "\n" +
    divider() + "\n  " +
    badge("GET") + "  " + dim("/") + "         list tasks\n  " +
    badge("GET") + "  " + dim("/stats") + "    server metrics\n  " +
    badge("POST") + " " + dim("/tasks") + "    add a task " + dim("(body = task text)") + "\n" +
    divider()

fn textResp(status: int, bodyText: string) -> HttpResponse = HttpResponse {
    status: status,
    headers: "Content-Type: text/plain",
    contentType: "text/plain",
    streamFd: -1,
    isComplete: true,
    partialBody: bodyText
}

// Adding a task touches every layer — Db records it, Persist writes the new
// snapshot to disk — yet not one socket, file descriptor or mutable field
// appears in this pure orchestration.
fn onPost(body: string) -> HttpResponse = {
    let id = perform Db.add(body)
    let snap = perform Db.list()
    let written = perform Persist.flush(snap)
    perform Log.info(badge("POST") + "  " + green("✚") + " " + bold(yellow("\"${body}\"")) + "  " + cyan("#${toString(id)}") + "  " + gauge(id) + dim("  ${toString(written)}B"))
    textResp(201, "created task #${toString(id)}\n")
}

fn onGet(path: string) -> HttpResponse = {
    perform Log.info(badge("GET") + " " + dim(path) + dim("  ·  ${toString(perform Metrics.served())} served"))
    match path {
        "/stats" => textResp(200, "requests=${toString(perform Metrics.served())} tasks=${toString(perform Db.count())}\n")
        _        => textResp(200, perform Db.list())
    }
}

fn handleReq(method: string, path: string, headers: string, body: string) -> HttpResponse = {
    perform Metrics.hit(path)
    match method {
        "POST" => onPost(body)
        _      => onGet(path)
    }
}

// httpListen returns once the accept thread is up; this keeps `main` (and the
// handler scope that owns all state) alive while requests are served.
fn serveForever() -> Unit = {
    sleep(3600000)
    serveForever()
}

fn main() -> int {
    mut logBuf = ""       // Log layer      (access log, mirrored to a file)
    mut diskBytes = 0     // Persist layer  (infrastructure)
    mut requests = 0      // Metrics layer  (server runtime)
    mut tasks = ""        // Db layer       (application data)
    mut taskCount = 0     // Db layer

    handle Persist
        flush snap => {
            let saved = writeFile("/tmp/osprey_tasks.db", snap)
            diskBytes = match saved {
                Success { value } => length(snap)
                Error { message } => -1
            }
            diskBytes
        }
    in handle Metrics
        hit p  => { requests = requests + 1 }
        served => requests
    in handle Db
        add t => {
            taskCount = taskCount + 1
            tasks = "${tasks}#${toString(taskCount)} ${t}\n"
            taskCount
        }
        list  => tasks
        count => taskCount
    in handle Log
        info m => {
            logBuf = "${logBuf}${m}\n"
            let w = writeFile("/tmp/osprey_server.log", logBuf)
            print("  ${m}")
        }
    in {
        let serverId = httpCreateServer(8080, "127.0.0.1")
        let listening = httpListen(serverId, handleReq)
        print(banner())
        serveForever()
        0
    }
}
