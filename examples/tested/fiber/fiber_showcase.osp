// Fiber + channel + select + yield + lambda showcase.
// Combines what fiber_concurrency_proof, fiber_isolation_test, fiber_test,
// fiber_final, fiber_advanced, simple_fiber were all proving piecemeal:
// — spawn/await produce real fiber IDs and out-of-order await works
// — yield returns the value passed back
// — Channel<T>+send/recv round-trip
// — select chooses a branch
// — fibers compose into a pipeline
// — lambdas work inside the program

fn simpleTask(value) = value * 100
fn handleRequest(id) = id
fn queryDatabase(userId) = userId * 1000

fn mapPhase(d) = d * d
fn fetchUserData(id) = id * 1000 + 123
fn fetchOrderData(id) = id * 100  + 45

fn authService(uid) = match uid {
    0 => 401
    _ => 200
}
fn inventoryService(pid) = pid * 50
fn paymentService(amt) = amt + 25
fn streamProcessor(b) = b * 8

fn stage1(x) = x + 100
fn stage2(x) = x * 2
fn stage3(x) = x - 50
fn combine(a, b) = a * 100 + b

print("=== Fiber Showcase ===")

// --- Out-of-order await proves fiber independence ---
let f1 = spawn simpleTask(1)
let f2 = spawn simpleTask(2)
let f3 = spawn simpleTask(3)
let f4 = spawn simpleTask(4)
print("ids ${f1} ${f2} ${f3} ${f4}")
print("await f3 = ${await(f3)}")
print("await f1 = ${await(f1)}")
print("await f4 = ${await(f4)}")
print("await f2 = ${await(f2)}")

// --- Map-Reduce ---
let m1 = spawn mapPhase(10)
let m2 = spawn mapPhase(20)
let m3 = spawn mapPhase(30)
let mappedTotal = await(m1) + await(m2) + await(m3)
print("map-reduce total = ${mappedTotal}")

// --- Microservices fan-out ---
let auth = spawn authService(123)
let inv  = spawn inventoryService(456)
let pay  = spawn paymentService(1000)
print("auth=${await(auth)} inv=${await(inv)} pay=${await(pay)}")

// --- Pipeline (each stage = its own fiber) ---
let p = await(spawn stage3(await(spawn stage2(await(spawn stage1(25))))))
print("pipeline = ${p}")

// --- Yield ---
let y1 = yield 25
let y2 = yield 50
let y3 = yield 75
print("yield ${y1} ${y2} ${y3}")
let advYield = fiber_yield(200)
print("fiber_yield = ${advYield}")

// --- Channel send/recv ---
let ch1 = Channel(1)
let ch2 = Channel(1)
send(ch1, 42)
print("recv ch1 = ${recv(ch1)}")
send(ch2, 123)
print("recv ch2 = ${recv(ch2)}")

// --- select ---
let priority = select {
    1 => 1000
    2 => 500
    3 => 100
}
print("select = ${priority}")

// --- Lambdas inline ---
let dbl   = fn(x) => x * 2
let tri   = fn(x) => x * 3
let addF  = fn(a, b) => a + b
print("lam dbl=${dbl(10)} tri=${tri(7)} add=${addF(5, 8)}")

// --- Stream processing via yield ---
let b1 = yield streamProcessor(128)
let b2 = yield streamProcessor(256)
let b3 = yield streamProcessor(512)
print("stream ${b1} ${b2} ${b3}")

// --- Simple request/db ---
let req = spawn handleRequest(1)
let db  = spawn queryDatabase(123)
print("req=${req} db=${await(db)}")

// --- API parallel calls ---
let u = spawn fetchUserData(5)
let o = spawn fetchOrderData(5)
print("user=${await(u)} order=${await(o)}")

// --- Captured-variable spawn + non-blocking completion probe ---
// `capArg` is a local captured into the spawned closure through a NAMED
// argument; fiberDone reports completion without blocking.
let capArg = 7
let capF = spawn combine(a: capArg, b: 5)
print("captured spawn = ${await(capF)} done=${fiberDone(capF)}")

print("=== Fiber Showcase Complete ===")
