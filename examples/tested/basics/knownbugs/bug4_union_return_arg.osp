type Outcome = Done { score: int } | Failed { code: int }
fn classify(s) = match s {
    0 => Failed { code: 99 }
    _ => Done   { score: s }
}
fn describe(o) = match o {
    Done   { score } => "done " + toString(score)
    Failed { code }  => "failed " + toString(code)
}
print(describe(Done { score: 27 }))
print(describe(classify(27)))
print(describe(classify(0)))
