// User-defined sum types: exercises construction + pattern matching on
// both arms, including arms that carry payload fields. Renamed away from
// the built-in `Result` so this file documents user-defined unions and
// not the Result<T, E> shape that ships with the language.

type Outcome = Ok { value: string } | Err { message: string }

type Status = Active | Inactive

fn describe(o) = match o {
    Ok { value } => "ok: " + value
    Err { message } => "err: " + message
}

fn label(s) = match s {
    Active => "active"
    Inactive => "inactive"
}

fn main() = {
    print(describe(Ok { value: "loaded" }))
    print(describe(Err { message: "missing" }))
    print(label(Active))
    print(label(Inactive))
}
