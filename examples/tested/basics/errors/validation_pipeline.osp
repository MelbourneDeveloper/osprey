// Input-validation pipeline built from USER-DEFINED fallible functions that
// return Result<int, string> and construct Error { message: "..." } directly.
// Proves user-constructed Error payloads propagate through match, exercising a
// nested match (parseInt's Result -> range check) and string interpolation of
// the threaded rejection reason. Iteration is recursion (Osprey has no loops).
// Spec: docs/specs/0012-Built-InFunctions.md [ERR-PAYLOAD]

// Plausible-age bounds as named constants (zero-arg fns are in scope
// everywhere; top-level `let`s are not visible inside fn bodies).
fn minAge() = 0
fn maxAge() = 150

// User-constructed Result variants, one per validation outcome. Each carries a
// specific, human-readable Error message that must survive to the match arm.
fn rejectNonNumber()   -> Result<int, string> = Error { message: "not a number" }
fn rejectNegative()    -> Result<int, string> = Error { message: "age must be non-negative" }
fn rejectTooLarge()    -> Result<int, string> = Error { message: "age unrealistically large" }
fn acceptAge(n)   -> Result<int, string> = Success { value: n }

// Range-check an already-parsed integer, returning a SPECIFIC Error per mode.
fn checkAgeRange(n) -> Result<int, string> = match n < minAge() {
    true  => rejectNegative()
    false => match n > maxAge() {
        true  => rejectTooLarge()
        false => acceptAge(n)
    }
}

// Parse a string to an int (nested match on parseInt's Result), then
// range-check it. parseInt's failure becomes our own "not a number" reason.
fn parseAge(s) -> Result<int, string> = match parseInt(s) {
    Success { value }   => checkAgeRange(value)
    Error   { message } => rejectNonNumber()
}

// Validate one input: print either the accepted value or the threaded reason.
fn validate(s) = match parseAge(s) {
    Success { value }   => print("input \"${s}\" -> accepted age ${value}")
    Error   { message } => print("input \"${s}\" -> rejected: ${message}")
}

// The inputs to drive the validator over, indexed by position.
fn inputAt(i) = match ["30", "-4", "999", "abc"][i] {
    Success { value }   => value
    Error   { message } => ""
}

// No loop construct: walk the inputs by index via tail recursion.
fn runAll(i, n) = match i < n {
    false => 0
    true  => match validate(inputAt(i)) {
        _ => runAll(i + 1, n)
    }
}

print("=== Validation Pipeline ===")
runAll(0, 4)

// Direct proof: each user-constructed Error message reaches the Error arm
// and is re-interpolated into another string ([ERR-PAYLOAD]). A nested
// match distinguishes the two distinct rejection reasons.
match parseAge("abc") {
    Success { value }   => print("unexpected success")
    Error   { message } => match parseAge("999") {
        Success { value2 }  => print("unexpected success")
        Error   { reason2 } => print("threaded reasons = \"${message}\" / \"${reason2}\"")
    }
}
print("=== Validation Pipeline Complete ===")
0
