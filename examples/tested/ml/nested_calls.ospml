// Deeply nested whitespace application: `inc (double (inc (double 3)))` threads
// a value through four calls inner-to-outer. Each unary function returns `int`
// per its signature, so the nested result interpolates as a plain int.

inc : int -> int
inc x = x + 1

double : int -> int
double x = x + x

neg : int -> int
neg x = 0 - x

deep = inc (double (inc (double 3)))
print "deep=${deep} mix=${neg (inc (double 5))} two=${double (double 4)}"
0
