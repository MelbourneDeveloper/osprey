// Default-flavor twin of curry_partial.ospml. ML curry-by-default `add a b = ...`
// lowers to explicit-curry `fn add(a) = fn(b) => ...`; partial application
// `add(5)` yields the inner closure. The `-> (int) -> int` annotation mirrors the
// ML signature and auto-unwraps the arithmetic Result — byte-identical IR.

fn add(a: int) -> (int) -> int = fn(b) => a + b

let add5 = add(5)
let add100 = add(100)
print("a=${add5(10)} b=${add5(0)} c=${add100(23)} full=${add(7)(8)}")
0
