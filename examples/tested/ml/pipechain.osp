// Default-flavor twin of pipechain.ospml. The `|>` pipe operator is shared by
// both flavors; each ML signature maps to a `-> int` annotation that auto-unwraps
// the arithmetic Result so the pipeline value is a plain int — byte-identical IR.

fn inc(x: int) -> int = x + 1
fn double(x: int) -> int = x + x
fn square(x: int) -> int = x * x

print("p1=${5 |> inc |> double} p2=${3 |> double |> square |> inc} p3=${10 |> inc |> inc |> double}")
0
