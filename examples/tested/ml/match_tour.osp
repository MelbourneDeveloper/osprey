// Default-flavor twin of match_tour.ospml. Layout `match` (scrutinee on the
// `match` line, indented `pattern => body` arms) lowers to the same
// `Expr::Match` + `MatchArm` nodes as this braced `match`, and the ML bare
// top-level script lowers to the same canonical AST as `fn main() = { ... }`.

fn classify(n) = match n {
    0 => "zero"
    1 => "one"
    _ => "many"
}

print(classify(0))
print(classify(1))
print(classify(9))
