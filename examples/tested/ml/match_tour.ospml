// Layout `match`: the scrutinee sits on the `match` line and each indented
// `pattern => body` arm lowers to the same `Expr::Match` + `MatchArm` the
// Default flavor's braced `match` produces.

classify n =
    match n
        0 => "zero"
        1 => "one"
        _ => "many"

print (classify 0)
print (classify 1)
print (classify 9)
