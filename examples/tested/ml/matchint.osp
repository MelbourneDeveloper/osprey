// Default-flavor twin of matchint.ospml. Layout `match` over int literals + `_`
// lowers to the same nodes as this braced `match`; the function returns a string
// so no auto-unwrap annotation is needed — byte-identical IR.

fn label(n) = match n {
    0 => "none"
    1 => "single"
    2 => "pair"
    _ => "many"
}

fn main() = {
    print("a=${label(0)} b=${label(1)} c=${label(2)} d=${label(7)}")
    0
}
