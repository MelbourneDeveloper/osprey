// A multi-stage `|>` pipeline threading a value through several unary functions.
// `a |> f |> g |> h` reads left-to-right as `h (g (f a))`. Each stage returns
// `int` (per its signature) so the pipeline value interpolates as a plain int.

inc : int -> int
inc x = x + 1

double : int -> int
double x = x + x

square : int -> int
square x = x * x

print "p1=${5 |> inc |> double} p2=${3 |> double |> square |> inc} p3=${10 |> inc |> inc |> double}"
0
