// Default-flavor twin of mixed.ospml. ML curry `scale k = \v => v * k` lowers to
// `fn scale(k) = fn(v) => v * k`; the layout `match`, `|>` pipe, value bindings
// (`let`), and `${...}` interpolation all lower identically. The annotations
// mirror the ML signatures and auto-unwrap arithmetic Results — byte-identical IR.

fn scale(k: int) -> (int) -> int = fn(v) => v * k

fn step(x: int) -> int = x + 1

fn sign(n: int) -> string = match n >= 0 {
    true => "pos"
    false => "neg"
}

let base = 7
let triple = scale(3)
let piped = base |> step |> step
print("triple=${triple(base)} piped=${piped} sign=${sign(base)} mix=${triple(step(base))}")
0
