// Layout `match` over integer literals plus a `_` wildcard, returning a string.
// The scrutinee sits on the `match` line; each indented `pattern => body` arm
// lowers to the same `Expr::Match` + `MatchArm` the braced form produces.

label n =
    match n
        0 => "none"
        1 => "single"
        2 => "pair"
        _ => "many"

main () =
    print "a=${label 0} b=${label 1} c=${label 2} d=${label 7}"
    0
