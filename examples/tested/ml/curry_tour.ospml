// ML flavor tour: layout blocks, multi-parameter (uncurried) functions,
// whitespace application, operators, match, lambdas, an explicit closure, pipes
// and interpolation. Lowers to the same canonical AST as the Default flavor
// (docs/specs/0023).

inc : int -> int
inc x = x + 1

add : int -> int -> int
add x y = x + y

square : int -> int
square n = n * n

// A function that returns a lambda — the curry-friendly closure idiom.
makeScaler : int -> (int) -> int
makeScaler k = \v => v * k

// match over integer literals and a wildcard.
name : int -> string
name n =
    match n
        0 => "zero"
        1 => "one"
        _ => toString n

// match over a boolean built from a comparison.
parity : int -> string
parity n =
    match n % 2 == 0
        true => "even"
        false => "odd"

main : Unit -> int
main () =
    base = add 40 2
    scaled = makeScaler 3
    print "base=${toString base} inc=${toString (inc base)} sq=${toString (square 9)}"
    print "scaled7=${toString (scaled 7)} curry=${toString (add 5 6)}"
    print "name0=${name 0} name1=${name 1} name9=${name 9}"
    print "parity7=${parity 7} parity8=${parity 8}"
    print "pipe=${toString (10 |> inc |> square)}"
    0
