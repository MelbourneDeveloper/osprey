// Default-flavor twin of nested_calls.ospml. ML whitespace application
// `inc (double (inc (double 3)))` lowers to the same call nesting as the braced
// `inc(double(inc(double(3))))`; the `-> int` returns mirror the ML signatures
// and auto-unwrap each arithmetic Result — byte-identical IR.

fn inc(x: int) -> int = x + 1
fn double(x: int) -> int = x + x
fn neg(x: int) -> int = 0 - x

let deep = inc(double(inc(double(3))))
print("deep=${deep} mix=${neg(inc(double(5)))} two=${double(double(4))}")
0
