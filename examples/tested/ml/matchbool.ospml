// `match` over a boolean built from a comparison: the scrutinee is an expression
// (`n >= threshold`) and the `true` / `false` arms return strings.

grade n =
    match n >= 50
        true => "pass"
        false => "fail"

even n =
    match n % 2 == 0
        true => "even"
        false => "odd"

print "g80=${grade 80} g20=${grade 20} e4=${even 4} e7=${even 7}"
0
