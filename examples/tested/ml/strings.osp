// Default-flavor twin of strings.ospml. ML 1-param `shout s = ...` lowers to
// `fn shout(s) = ...`, value bindings to `let`, the bare script to
// `fn main() = { ... }`, and `+` string concat plus `${...}` interpolation are
// shared — byte-identical IR.

fn shout(s) = s + "!"
fn greet(who) = "Hi " + who

let name = "Ada"
let hello = greet(name)
print("plain=${hello} loud=${shout(hello)} both=${shout(greet(name))} concat=${hello + name}")
