// Default-flavor twin of mutation.ospml. ML `mut name = e` lowers to
// `Stmt::Let { mutable: true }` and `name := e` to `Stmt::Assignment` — the same
// nodes Default emits for `mut` and reassignment. Arithmetic auto-unwraps into
// the int cell, so the IR is byte-identical.

mut counter = 0
counter = counter + 1
counter = counter + 41
print("counter = ${counter}")
