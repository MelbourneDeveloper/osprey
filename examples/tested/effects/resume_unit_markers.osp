// Explicit resume with a Unit-returning operation.

effect Trace {
    mark: fn(string) -> Unit
}

fn traced() -> int !Trace = {
    perform Trace.mark("one")
    perform Trace.mark("two")
    7
}

let result = handle Trace
    mark label => {
        print("before " + label)
        let final = resume()
        print("after " + label + ": final=" + toString(final))
        final
    }
in traced()
print("result=" + toString(result))
