effect Trace
    mark : string => Unit

traced : Unit -> int ! Trace
traced () =
    perform Trace.mark "one"
    perform Trace.mark "two"
    7

result =
    handle Trace
        mark label =>
            print ("before " + label)
            final = resume
            print ("after " + label + ": final=" + toString final)
            final
    in traced ()
print ("result=" + toString result)
