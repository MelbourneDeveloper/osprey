{
  "name": "Osprey Programming Language Dev Environment (ARM64 - Local Development)",
  "dockerComposeFile": "docker-compose.yml",
  "service": "osprey-dev-arm64",
  "runArgs": ["--platform=linux/arm64"],
  "workspaceFolder": "/workspace",
  "shutdownAction": "stopCompose",
  "customizations": {
    "vscode": {
      "settings": {
        "go.useLanguageServer": true,
        "go.formatTool": "goimports",
        "go.lintOnSave": "package",
        "go.testFlags": [
          "-v"
        ],
        "go.toolsManagement.checkForUpdates": "local",
        "go.goroot": "/usr/local/go",
        "go.gopath": "/go",
        "go.testWorkingDirectory": "${workspaceFolder}/compiler",
        "go.testExplorer.enable": true,
        "rust-analyzer.check.command": "clippy",
        "rust-analyzer.cargo.buildScripts.enable": true,
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.organizeImports": "explicit"
        },
        "terminal.integrated.defaultProfile.linux": "bash",
        "git.autofetch": true,
        "git.confirmSync": false,
        "C_Cpp.default.cStandard": "c11",
        "C_Cpp.default.cppStandard": "c++17",
        "C_Cpp.default.compilerPath": "/usr/bin/clang-14",
        "C_Cpp.default.compilerArgs": [
          "-Wall",
          "-Wextra", 
          "-Werror",
          "-Wpedantic",
          "-std=c11",
          "-pthread"
        ],
        "C_Cpp.default.includePath": [
          "${workspaceFolder}/compiler/runtime"
        ]
      },
      "extensions": [
        "golang.go",
        "rust-lang.rust-analyzer",
        "antlr.antlr4",
        "llvm-vs-code-extensions.vscode-clangd",
        "ms-vscode.makefile-tools",
        "ms-vscode.test-adapter-converter",
        "twxs.cmake",
        "ms-vscode.cmake-tools",
        "ms-vscode.makefile-tools"
      ]
    }
  },
  "remoteUser": "root",
  "forwardPorts": [
    3001,
    8080
  ],
  "portsAttributes": {
    "3001": {
      "label": "Web Compiler",
      "onAutoForward": "notify"
    },
    "8080": {
      "label": "Development Server",
      "onAutoForward": "notify"
    }
  },
  "postCreateCommand": "echo 'ARM64 development container ready for local development!'"
}
