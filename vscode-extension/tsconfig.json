{
  "compilerOptions": {
    "module": "node16",
    "target": "es2020",
    "outDir": "out",
    "lib": ["es2020"],
    "types": ["node", "mocha", "vscode"],
    "sourceMap": true,
    "rootDir": ".",
    "strict": true,
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["client/src/**/*", "test/**/*.ts"],
  "exclude": ["node_modules", ".vscode-test"]
}
