# Source files
client/src/**
*.ts
tsconfig.json

# Build and development files
.cursor/**
.vscode/**
.vscode-test/**
.vscode-test.js
.DS_Store
.c8rc.json
coverage/**
test/**
scripts/**
test.log
*.vsix

# Exclude development dependencies but keep production dependencies
node_modules/@types/**
node_modules/@vscode/**
node_modules/mocha/**
node_modules/sinon/**
node_modules/ts-node/**
node_modules/typescript/**

# Exclude test and cache files from all node_modules
node_modules/**/.cache
node_modules/**/test
node_modules/**/tests
node_modules/**/*.test.js
node_modules/**/*.spec.js
node_modules/**/.*

# Documentation and development files
TESTING.md
FEATURES.md
build.sh
run-tests.sh
test-runner.js
.nvmrc
.gitignore

# Keep only essential files
!out/client/**
out/test/**
out/tsconfig.tsbuildinfo
# Bundled, version-matched osprey compiler + C runtime archives (libfiber/libhttp)
# staged by `make _vsix_bundle`. resolveBundledCompiler() loads bin/<platform>/osprey,
# and the compiler links the .a archives sitting beside it for `--run`.
!bin/**
!syntaxes/**
!language-configuration/**
!language-configuration-ml.json
!snippets/**
!package.json
!README.md
!LICENSE
!icon.png
!node_modules/vscode-languageclient/**
