// Simple substring test to exercise core_functions.go

fn main() -> int {
    let text = "hello world"
    
    // Test substring function - should exercise generateSubstringCall
    let result1 = substring(text, 0, 5)
    match result1 {
        Success { value } => print("Substring: ${value}")
        Error { message } => print("Error in substring")
    }
    
    // Test another substring
    let result2 = substring(text, 6, 11)
    match result2 {
        Success { value } => print("Substring: ${value}")
        Error { message } => print("Error in substring")
    }
    
    0
}