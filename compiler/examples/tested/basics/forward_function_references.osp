effect Logger {
    log: fn(string) -> Unit
}

fn main() -> Unit = {
    handle Logger
        log msg => print(msg)
    in {
        let result = nestedCall()
        print(toString(result))
    }
}

fn deepNestedOperation() -> int !Logger = {
    perform Logger.log("deep")
    42
}

fn nestedCall() -> int !Logger = {
    perform Logger.log("before")
    deepNestedOperation()
}
