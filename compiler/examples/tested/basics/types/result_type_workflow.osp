// Implements [BUILTIN-STRING-INSPECTION], [BUILTIN-STRING-SEARCH].
// After the [BUILTIN-STRING-*] unwrap (see plans/string-manipulation.md
// workstream A1), length and contains return raw values; no match needed.

fn main() -> int {
  print("=== Result Type Workflow Test ===\n")

  let s = "hello"
  print("Length: ${length(s)}\n")
  print("Contains 'ell': ${contains(s, "ell")}\n")
  print("Contains 'xyz': ${contains(s, "xyz")}\n")
  0
}
