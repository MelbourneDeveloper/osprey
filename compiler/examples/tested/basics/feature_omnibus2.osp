// Second omnibus — float printing, error-path Result, bool printing,
// effect handler scoping.

fn main() -> int {
  print("=== omnibus2 ===")

  let f = 1.5
  print(f)

  match parseInt("oops") {
    Success { value }   => print("got ${value}")
    Error   { message } => print(message)
  }

  let yes = 5 == 5
  let no  = 5 == 6
  print(yes)
  print(no)

  let s = "hi" + " " + "world"
  print(s)

  print("=== omnibus2 done ===")
  0
}
