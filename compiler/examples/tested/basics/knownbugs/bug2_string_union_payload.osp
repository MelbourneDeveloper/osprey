type Outcome = Done { score: int } | Failed { reason: string }
fn classify(score: int) -> Outcome = match score {
    0 => Failed { reason: "empty" }
    _ => Done   { score: score }
}
fn describe(o: Outcome) -> string = match o {
    Done   { score }  => "done " + toString(score)
    Failed { reason } => "failed " + reason
}
print(describe(classify(27)))
print(describe(classify(0)))
