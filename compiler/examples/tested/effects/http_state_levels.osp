// ============================================================================
//  Osprey reference app — STATE AT EVERY LEVEL OF AN HTTP API, with algebraic
//  effects. A live HTTP server keeps ALL of its state inside effect handlers:
//  the request handler is pure (it only `perform`s), and each architectural
//  layer owns its mutable state in the handler installed at that layer.
//
//      Persist  (infrastructure)  owns the on-disk snapshot   — writes a file
//      Metrics  (server runtime)  owns the request counter     — bumped per call
//      Db       (application)     owns the task table           — the domain data
//
//  Handler-owned state is just a `mut` the handler closes over: `perform`
//  threads a value through it and the performer resumes, so the State effect is
//  real — not a value-substitution stub. The effects even cross the C HTTP
//  callback boundary (the server runs the pure handler) AND fiber boundaries
//  (each task is posted on its own fiber, below). Swap the handlers in `main`
//  and the same server logic runs against a mock — nothing else changes.
// ============================================================================

// ---- the three state layers, one effect each (+ logging) -------------------
effect Db {
    add:   fn(string) -> int      // append a task, returns its id
    list:  fn() -> string         // the rendered task table
    count: fn() -> int            // how many tasks exist
}
effect Metrics {
    hit:    fn(string) -> Unit    // record one served request
    served: fn() -> int           // total requests served since boot
}
effect Persist {
    flush: fn(string) -> int      // durably write a snapshot, returns bytes
    bytes: fn() -> int            // bytes last written to disk
}
effect Log { info: fn(string) -> Unit }

// ---- HTTP plumbing helpers (pure) ------------------------------------------
fn textResp(status: int, bodyText: string) -> HttpResponse = HttpResponse {
    status: status,
    headers: "Content-Type: text/plain",
    contentType: "text/plain",
    streamFd: -1,
    isComplete: true,
    partialBody: bodyText
}

// ---- the request handler: PURE orchestration, only `perform` --------------
// Adding a task touches every layer: Db records it, Persist writes the new
// snapshot to disk, and the reply reports both — yet not one socket, file
// descriptor or mutable field appears here.
fn onPost(body: string) -> HttpResponse = {
    let id = perform Db.add(body)
    let snap = perform Db.list()
    let written = perform Persist.flush(snap)
    textResp(201, "created task #${toString(id)} (${toString(written)}B persisted)")
}

fn onGet(path: string) -> HttpResponse = match path {
    "/stats" => textResp(200, "requests=${toString(perform Metrics.served())} tasks=${toString(perform Db.count())}")
    _        => textResp(200, perform Db.list())
}

fn handleReq(method: string, path: string, headers: string, body: string) -> HttpResponse = {
    perform Metrics.hit(path)
    match method {
        "POST" => onPost(body)
        _      => onGet(path)
    }
}

// ---- client side: read a response body and release the handle --------------
fn bodyOf(h: int) -> string = match httpResponseBody(h) {
    Success { value } => value
    Error { message } => "(no body)"
}

fn readAndFree(h: int) -> string = {
    let b = bodyOf(h)
    let freed = httpResponseFree(h)
    b
}

fn fetch(clientId: int, path: string) -> string = match httpGetResponse(clientId, path, "") {
    Success { value } => readAndFree(value)
    Error { message } => "GET failed"
}

// Post a task over HTTP. The reply reports the server's status code; the `Log`
// effect (handled in `main`) traces the call.
fn postTask(clientId: int, text: string) -> Unit = {
    perform Log.info("POST /tasks <- ${text}")
    print("  server replied ${toString(httpPost(clientId, "/tasks", text, ""))}")
}

// Seed one task from a BACKGROUND FIBER. `Db.add` is performed inside the
// fiber yet handled back in `main` — handler-owned state mutated across the
// fiber boundary — and the new id (an int) rides back through `await`.
fn seedTask(text: string) -> int = perform Db.add(text)

// ---- the demo driver: a tiny scripted client over the live server ----------
fn runDemo() -> Unit = {
    let serverId = httpCreateServer(18280, "127.0.0.1")
    let listening = httpListen(serverId, handleReq)
    let clientId = httpCreateClient("http://127.0.0.1:18280", 5000)
    print("server up on :18280")
    let seeded = await(spawn seedTask("welcome to osprey"))
    print("seeded task #${toString(seeded)} from a background fiber")
    postTask(clientId: clientId, text: "buy oat milk")
    postTask(clientId: clientId, text: "land the effects PR")
    let listing = fetch(clientId: clientId, path: "/tasks")
    print("--- GET /tasks ---\n${listing}--- end ---")
    print("GET /stats -> ${fetch(clientId: clientId, path: "/stats")}")
    let stopped = httpStopServer(serverId)
    print("STATE @ shutdown — db: ${toString(perform Db.count())} tasks | server: ${toString(perform Metrics.served())} requests | disk: ${toString(perform Persist.bytes())} bytes")
}

// ---- main installs the handlers — the ONLY place state lives ---------------
// The `mut` cells below are owned by their handlers: the arms read and write
// them, and the running server mutates them through every request.
fn main() -> int {
    mut diskBytes = 0     // Persist layer  (infrastructure)
    mut requests = 0      // Metrics layer  (server runtime)
    mut tasks = ""        // Db layer       (application data)
    mut taskCount = 0     // Db layer

    handle Persist
        flush snap => {
            let saved = writeFile("/tmp/osprey_tasks.db", snap)
            diskBytes = match saved {
                Success { value } => length(snap)
                Error { message } => -1
            }
            diskBytes
        }
        bytes => diskBytes
    in handle Metrics
        hit p      => { requests = requests + 1 }
        served     => requests
    in handle Db
        add t => {
            taskCount = taskCount + 1
            tasks = "${tasks}#${toString(taskCount)} ${t}\n"
            taskCount
        }
        list  => tasks
        count => taskCount
    in handle Log
        info m => print("[client] ${m}")
    in {
        runDemo()
        0
    }
}
