// Exercises the HTTP response-handle lifecycle against a local server: status,
// body, header lookup, missing-header error, free, and a double-free that must
// report Error (not crash). Each Result-returning op lives in its own helper so
// the handle is never reused across a nested match. Implements [HTTP-RESPONSE-HANDLE].

fn handleRequest(method: string, path: string, headers: string, body: string) -> HttpResponse = HttpResponse {
    status: 200,
    headers: "X-Demo: hi\r\n",
    contentType: "text/plain",
    streamFd: -1,
    isComplete: true,
    partialBody: "hello body"
}

fn bodyLine(h: int) -> string = {
    let r = httpResponseBody(h)
    match r {
        Success { value } => "body=${value}"
        Error { message } => "nobody"
    }
}

fn headerLine(h: int, name: string) -> string = {
    let r = httpResponseHeader(h, name)
    match r {
        Success { value } => "hdr=${value}"
        Error { message } => "missing-ok"
    }
}

fn freeLine(h: int) -> string = {
    let r = httpResponseFree(h)
    match r {
        Success { value } => "free-ok"
        Error { message } => "free-err-double"
    }
}

fn run() -> Unit = {
    let serverId = httpCreateServer(18095, "127.0.0.1")
    let listenResult = httpListen(serverId, handleRequest)
    let clientId = httpCreateClient("http://127.0.0.1:18095", 5000)
    let resp = httpGetResponse(clientId, "/", "")
    match resp {
        Success { value } => {
            print("status=${httpResponseStatus(value)}")
            print(bodyLine(h: value))
            print(headerLine(h: value, name: "X-Demo"))
            print(headerLine(h: value, name: "Nope"))
            print(freeLine(h: value))
            print(freeLine(h: value))
        }
        Error { message } => print("reqfail ${message}")
    }
    let closeResult = httpCloseClient(clientId)
    let stopResult = httpStopServer(serverId)
}

run()
