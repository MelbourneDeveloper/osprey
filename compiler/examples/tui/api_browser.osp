// ============================================================================
//  Osprey TUI showcase: a colored, arrow-key-driven browser over a REAL HTTP
//  API, written in the algebraic-effects style. Run it:
//
//      osprey examples/tui/api_browser.osp --run
//
//  Repo list:  Up/Down (or k/j) move   Enter browse files   q/Esc quit
//  File tree:  Up/Down move   Enter open dir or view source   Esc go back
//  Drill into any directory and open a file to read its source, downloaded
//  live; navigation depth is just the call stack (descend = recurse, back =
//  return), so there is no mutable path state anywhere.
//
//  Every side effect is an ALGEBRAIC EFFECT. The program logic never touches
//  a socket, a file descriptor or a terminal ioctl - it only `perform`s:
//      perform Console.print(line)        -- write a line of output
//      perform Terminal.readKey()         -- await one keystroke
//      perform Terminal.raw(1)            -- enter/leave raw mode
//      perform Http.fetch(path)           -- GET JSON, yield the body
//      perform Http.fetchRaw(path)        -- GET a file's raw source
//  The messy interpretation - opening a TLS client, reading the response,
//  freeing the handle, closing the client, calling tcsetattr - lives ONLY in
//  the handlers installed by `main`. The `Http` handler even runs the request
//  on a background FIBER and animates a spinner on the foreground thread while
//  it waits (see `awaitSpinning`): true overlap, real frames, zero blocking.
//  Swap those handlers and the same UI runs against a mock, with no changes
//  to the logic below.
//
//  The render loop is recursion (Osprey has no loop keyword); each keystroke
//  tail-calls the next frame. Screens are strings built by composing pure
//  functions. Terminal control codes are just text folded into those strings.
//  [BUILTIN-JSON] jsonParse/jsonGet/jsonLength, [HTTP-RESPONSE-HANDLE],
//  [BUILTIN-TERM], fiberDone non-blocking probe, \e ANSI.
// ============================================================================

// ---- effects: the complete vocabulary of side effects this program has ------
effect Console { print: fn(string) -> Unit }
effect Terminal {
    readKey: fn() -> Result<string, Error>
    raw:     fn(int) -> Unit
}
effect Http {
    fetch:    fn(string) -> Result<string, Error>   // GET JSON (listings)
    fetchRaw: fn(string) -> Result<string, Error>   // GET raw bytes (file source)
}

// Which GitHub account's public repositories to browse.
fn githubUser() -> string = "MelbourneDeveloper"

// ---- ANSI color helpers (pure string wrappers) -----------------------------
fn cyan(s: string) -> string = "\e[36m${s}\e[0m"
fn green(s: string) -> string = "\e[32m${s}\e[0m"
fn yellow(s: string) -> string = "\e[33m${s}\e[0m"
fn magenta(s: string) -> string = "\e[35m${s}\e[0m"
fn blue(s: string) -> string = "\e[34m${s}\e[0m"
fn bold(s: string) -> string = "\e[1m${s}\e[0m"
fn dim(s: string) -> string = "\e[2m${s}\e[0m"
fn invert(s: string) -> string = "\e[7m${s}\e[0m"

fn rule() -> string = dim("  ==================================================")

// ---- tiny int helpers (int context makes +/- yield a plain int) -------------
fn inc(x: int) -> int = x + 1
fn dec(x: int) -> int = x - 1
fn min(a: int, b: int) -> int = match a < b { true => a false => b }
fn gap(a: int, b: int) -> int = match a < b { true => b - a false => a - b }
// Plain (unchecked) modulo: in `int` context `%` yields an int, so the result
// can be pattern-matched against integer literals (a bare `match x % n` would
// otherwise infer Result<int, MathError> and never match a literal arm).
fn modv(a: int, b: int) -> int = a % b

// ---- Result-unwrapping helpers (one expression each) ------------------------
fn pad(s: string, n: int) -> string = match padEnd(s, n, " ") {
    Success { value } => value
    Error { message } => s
}

fn field(doc: int, path: string) -> string = match jsonGet(doc, path) {
    Success { value } => value
    Error { message } => "?"
}

// ============================================================================
//  THE ANIMATED LOADER - an astounding full-screen spinner. Every frame is a
//  pure string; the Http handler prints them while the request runs on a fiber.
// ============================================================================

// Ten-frame braille rotor - the smoothest spinner glyph there is.
fn rotor(frame: int) -> string = match modv(a: frame, b: 10) {
    0 => "⠋" 1 => "⠙" 2 => "⠹" 3 => "⠸" 4 => "⠼"
    5 => "⠴" 6 => "⠦" 7 => "⠧" 8 => "⠇" _ => "⠏"
}

// Cycling rainbow escape, picked by frame so the colors flow.
fn hue(frame: int) -> string = match modv(a: frame, b: 6) {
    0 => "\e[91m" 1 => "\e[93m" 2 => "\e[92m" 3 => "\e[96m" 4 => "\e[94m" _ => "\e[95m"
}

// Three rotors at staggered phases + staggered hues = a flowing comet of dots.
fn comet(frame: int) -> string =
    hue(frame) + rotor(frame) + hue(inc(inc(frame))) + rotor(inc(inc(inc(frame)))) +
    hue(inc(inc(inc(inc(frame))))) + rotor(frame + 6) + "\e[0m"

// Animated trailing dots: "" . .. ...
fn dots(frame: int) -> string = match modv(a: frame, b: 4) {
    0 => "   " 1 => ".  " 2 => ".. " _ => "..."
}

// Knight-rider wave: a bright cell sweeps a 36-wide bar, bouncing at the ends.
fn waveWidth() -> int = 36
fn wavePos(frame: int) -> int = match (frame % 70) < waveWidth() {
    true  => frame % 70
    false => 70 - (frame % 70)
}
fn waveCell(i: int, pos: int, frame: int) -> string = match gap(a: i, b: pos) {
    0 => hue(frame) + "█\e[0m"
    1 => "\e[96m▓\e[0m"
    2 => "\e[36m▒\e[0m"
    _ => "\e[2m░\e[0m"
}
fn waveBar(i: int, pos: int, frame: int) -> string = match i < waveWidth() {
    true  => waveCell(i: i, pos: pos, frame: frame) + waveBar(i: inc(i), pos: pos, frame: frame)
    false => ""
}

// One full frame of the loader, addressed to a freshly-cleared screen.
fn loaderFrame(frame: int) -> string =
    "\e[?25l\e[2J\e[H\n\n\n\n" +
    "          " + bold(cyan("O S P R E Y")) + dim("  github browser") + "\n\n" +
    "          " + comet(frame) + bold("   Talking to GitHub") + hue(frame) + dots(frame) + "\e[0m\n\n" +
    "       " + waveBar(i: 0, pos: wavePos(frame), frame: frame) + "\n\n" +
    "          " + dim("live HTTPS  -  api.github.com  -  press q to quit")

// ---- list rendering: each row is a string, the list folds via recursion -----
fn rowLine(i: int, sel: int, nameP: string, starP: string, lang: string) -> string = match i == sel {
    true  => "  " + cyan(">") + " " + invert(" " + nameP + "* " + starP + lang + " ")
    false => "    " + bold(nameP) + yellow("* " + starP) + dim(lang)
}

fn rowText(doc: int, i: int, sel: int) -> string = rowLine(
    i: i,
    sel: sel,
    nameP: pad(s: field(doc: doc, path: "[${i}].name"), n: 20),
    starP: pad(s: field(doc: doc, path: "[${i}].stargazers_count"), n: 7),
    lang: field(doc: doc, path: "[${i}].language"))

fn rowsText(doc: int, i: int, sel: int, n: int) -> string = match i < n {
    true  => rowText(doc: doc, i: i, sel: sel) + "\n" + rowsText(doc: doc, i: inc(i), sel: sel, n: n)
    false => ""
}

fn screenText(doc: int, sel: int, n: int) -> string =
    "\n" +
    bold(cyan("  OSPREY  -  GitHub Repos: ${githubUser()}  (live API)")) + "\n" +
    rule() + "\n\n" +
    rowsText(doc: doc, i: 0, sel: sel, n: n) + "\n" +
    rule() + "\n" +
    dim("  up/down or j/k move    enter details    q quit")

// ---- detail view: shows the repo header + its LIVE file tree (/contents) ----
// Each tree entry exposes name / type / size / path. `path` is the full path
// from the repo root, so descending needs no manual path joins.
fn entType(tree: int, i: int) -> string = field(doc: tree, path: "[${i}].type")
fn entName(tree: int, i: int) -> string = field(doc: tree, path: "[${i}].name")
fn entSize(tree: int, i: int) -> string = field(doc: tree, path: "[${i}].size")
fn entPath(tree: int, i: int) -> string = field(doc: tree, path: "[${i}].path")

fn icon(t: string) -> string = match t { "dir" => "▸" _ => "·" }
fn sizeText(t: string, s: string) -> string = match t { "dir" => "" _ => s + " B" }
fn nameColor(t: string, s: string) -> string = match t { "dir" => "\e[1;34m${s}\e[0m" _ => s }

// One file-tree row; the selected row is inverted, like the repo list.
fn treeRow(tree: int, i: int, sel: int) -> string = match i == sel {
    true  => "  " + cyan(">") + " " + invert(" " + icon(t: entType(tree: tree, i: i)) + " " +
             pad(s: entName(tree: tree, i: i), n: 34) +
             pad(s: sizeText(t: entType(tree: tree, i: i), s: entSize(tree: tree, i: i)), n: 12) + " ")
    false => "    " + nameColor(t: entType(tree: tree, i: i),
             s: icon(t: entType(tree: tree, i: i)) + " " + pad(s: entName(tree: tree, i: i), n: 34)) +
             dim(sizeText(t: entType(tree: tree, i: i), s: entSize(tree: tree, i: i)))
}

// A scrolling window keeps the cursor on screen for big directories.
fn winStart(sel: int, n: int) -> int = match n < 23 {
    true  => 0
    false => match sel < 11 { true => 0 false => min(a: sel - 11, b: n - 22) }
}
fn treeRows(tree: int, i: int, last: int, sel: int) -> string = match i < last {
    true  => treeRow(tree: tree, i: i, sel: sel) + "\n" + treeRows(tree: tree, i: inc(i), last: last, sel: sel)
    false => ""
}

fn treeScreen(repo: string, path: string, tree: int, sel: int, n: int) -> string =
    "\e[?25l\e[2J\e[H\n  " +
    bold(cyan("FILES  ")) + green(repo) + dim("/" + path) + "\n" +
    rule() + "\n\n" +
    treeRows(tree: tree, i: winStart(sel: sel, n: n),
             last: min(a: winStart(sel: sel, n: n) + 22, b: n), sel: sel) + "\n" +
    rule() + "\n" +
    dim("  up/down move    enter open dir/file    esc back")

// The code viewer: the file's raw source, downloaded live, with a header.
fn codeScreen(file: string, code: string) -> string =
    "\e[?25l\e[2J\e[H\n  " +
    bold(magenta("CODE  ")) + green(file) + dim("   (${length(code)} bytes, live raw)") + "\n" +
    rule() + "\n\n" +
    take(code, 2400) + "\n\n" +
    rule() + "\n" +
    dim("  press any key to go back")

// ---- selection movement (pure int -> int) -----------------------------------
fn moveUp(sel: int) -> int = match sel > 0 {
    true  => dec(sel)
    false => sel
}
fn moveDown(sel: int, n: int) -> int = match sel < dec(n) {
    true  => inc(sel)
    false => sel
}

// ---- the UI: pure effect logic. No I/O primitives appear below. -------------
fn drawScreen(doc: int, sel: int, n: int) -> Unit !Console =
    perform Console.print("\e[?25l\e[2J\e[H" + screenText(doc: doc, sel: sel, n: n))

fn endApp() -> Unit ![Console, Terminal] = {
    perform Terminal.raw(0)
    perform Console.print("\e[?25h" + green("  Goodbye!"))
}

// ---- the file-system browser: navigate dirs, view source -------------------
// Navigation depth lives in the call stack: descending into a directory calls
// browseDir recursively, and pressing Esc simply RETURNS to the caller, which
// re-displays the parent level. At the repo root, returning lands back in the
// repository list. No mutable path stack - the recursion *is* the stack.
fn contentsPath(repo: string, path: string) -> string = match path {
    "" => "/repos/" + githubUser() + "/" + repo + "/contents"
    _  => "/repos/" + githubUser() + "/" + repo + "/contents/" + path
}

// Build the path string for the repository list's "Enter" action.
fn openRepo(doc: int, sel: int, n: int) -> Unit ![Console, Terminal, Http] = {
    browseDir(repo: field(doc: doc, path: "[${sel}].name"), path: "")
    uiLoop(doc: doc, sel: sel, n: n)
}

// Fetch a directory listing (animated loader fires inside the handler) and run
// the interactive browser over it. Returns when the user navigates back out.
fn browseDir(repo: string, path: string) -> Unit ![Console, Terminal, Http] =
    match perform Http.fetch(contentsPath(repo: repo, path: path)) {
        Success { text } => openTree(repo: repo, path: path, body: text)
        Error { message } => waitMessage(msg: "Could not open /" + path)
    }

fn openTree(repo: string, path: string, body: string) -> Unit ![Console, Terminal, Http] = match jsonParse(body) {
    Success { tree } => browseLoop(repo: repo, path: path, tree: tree, sel: 0, n: jsonLength(tree, ""))
    Error { message } => waitMessage(msg: "Could not read /" + path)
}

fn browseLoop(repo: string, path: string, tree: int, sel: int, n: int) -> Unit ![Console, Terminal, Http] = {
    perform Console.print(treeScreen(repo: repo, path: path, tree: tree, sel: sel, n: n))
    match perform Terminal.readKey() {
        Success { value } => browseKey(repo: repo, path: path, tree: tree, sel: sel, n: n, key: value)
        Error { message } => perform Console.print("")
    }
}

fn browseKey(repo: string, path: string, tree: int, sel: int, n: int, key: string) -> Unit ![Console, Terminal, Http] = match key {
    "Up"    => browseLoop(repo: repo, path: path, tree: tree, sel: moveUp(sel), n: n)
    "k"     => browseLoop(repo: repo, path: path, tree: tree, sel: moveUp(sel), n: n)
    "Down"  => browseLoop(repo: repo, path: path, tree: tree, sel: moveDown(sel: sel, n: n), n: n)
    "j"     => browseLoop(repo: repo, path: path, tree: tree, sel: moveDown(sel: sel, n: n), n: n)
    "Enter" => openEntry(repo: repo, path: path, tree: tree, sel: sel, n: n)
    "Esc"   => perform Console.print("")
    "u"     => perform Console.print("")
    _       => browseLoop(repo: repo, path: path, tree: tree, sel: sel, n: n)
}

// Enter on a dir descends (recursion); Enter on a file views its source. Either
// way, control flows back here afterwards to re-display this directory level.
fn openEntry(repo: string, path: string, tree: int, sel: int, n: int) -> Unit ![Console, Terminal, Http] = match entType(tree: tree, i: sel) {
    "dir" => descend(repo: repo, path: path, tree: tree, sel: sel, n: n)
    _     => openFile(repo: repo, path: path, tree: tree, sel: sel, n: n)
}

fn descend(repo: string, path: string, tree: int, sel: int, n: int) -> Unit ![Console, Terminal, Http] = {
    browseDir(repo: repo, path: entPath(tree: tree, i: sel))
    browseLoop(repo: repo, path: path, tree: tree, sel: sel, n: n)
}

fn openFile(repo: string, path: string, tree: int, sel: int, n: int) -> Unit ![Console, Terminal, Http] = {
    viewFile(repo: repo, file: entPath(tree: tree, i: sel))
    browseLoop(repo: repo, path: path, tree: tree, sel: sel, n: n)
}

fn viewFile(repo: string, file: string) -> Unit ![Console, Terminal, Http] =
    match perform Http.fetchRaw(contentsPath(repo: repo, path: file)) {
        Success { text } => showCode(file: file, code: text)
        Error { message } => waitMessage(msg: "Could not read " + file)
    }

fn showCode(file: string, code: string) -> Unit ![Console, Terminal] = {
    perform Console.print(codeScreen(file: file, code: code))
    match perform Terminal.readKey() { _ => perform Console.print("") }
}

fn waitMessage(msg: string) -> Unit ![Console, Terminal] = {
    perform Console.print("\e[?25l\e[2J\e[H\n  " + magenta(msg))
    match perform Terminal.readKey() { _ => perform Console.print("") }
}

// ---- the render / input loop (recursion stands in for a while-loop) ---------
fn uiLoop(doc: int, sel: int, n: int) -> Unit ![Console, Terminal, Http] = {
    drawScreen(doc: doc, sel: sel, n: n)
    match perform Terminal.readKey() {
        Success { value } => handleKey(doc: doc, sel: sel, n: n, key: value)
        Error { message }  => endApp()
    }
}

fn handleKey(doc: int, sel: int, n: int, key: string) -> Unit ![Console, Terminal, Http] = match key {
    "q"     => endApp()
    "Esc"   => endApp()
    "Up"    => uiLoop(doc: doc, sel: moveUp(sel), n: n)
    "k"     => uiLoop(doc: doc, sel: moveUp(sel), n: n)
    "Down"  => uiLoop(doc: doc, sel: moveDown(sel: sel, n: n), n: n)
    "j"     => uiLoop(doc: doc, sel: moveDown(sel: sel, n: n), n: n)
    "Enter" => openRepo(doc: doc, sel: sel, n: n)
    _       => uiLoop(doc: doc, sel: sel, n: n)
}

// startUi enters raw mode + the alternate screen and runs the loop over the
// live repository list. Raw mode is requested as an effect, not a syscall.
fn startUi(bodyText: string) -> Unit ![Console, Terminal, Http] = match jsonParse(bodyText) {
    Success { value } => {
        perform Terminal.raw(1)
        uiLoop(doc: value, sel: 0, n: jsonLength(value, ""))
    }
    Error { message } => perform Console.print("JSON parse failed")
}

// The whole program in one effectful expression: fetch, then browse the result.
fn app() -> Unit ![Console, Terminal, Http] = match perform Http.fetch("/users/${githubUser()}/repos?per_page=30&sort=updated") {
    Success { text } => startUi(text)
    Error { message } => perform Console.print("Request failed: ${message}")
}

// ============================================================================
//  INTERPRETATION: the ONLY place real I/O happens.
//  The Http handler runs the GET on a background fiber and animates the loader
//  on this thread until `fiberDone` reports the response is ready - then reads
//  the body, frees the handle and closes the client, threading the body Result
//  through untouched. No locals: the Result rides through as a parameter.
// ============================================================================
fn ghHeaders() -> string = "User-Agent: osprey-tui\r\nAccept: application/vnd.github+json\r\n"
fn rawHeaders() -> string = "User-Agent: osprey-tui\r\nAccept: application/vnd.github.raw\r\n"

// Runs on a fiber. Returns the response handle (> 0), or 0 to signal failure.
fn rawGet(clientId: int, path: string, headers: string) -> int = match httpGetResponse(clientId, path, headers) {
    Success { value } => value
    Error { message } => 0
}

// Foreground animation loop: paint a frame, nap, re-probe - exit the instant
// the fiber finishes and hand back the (awaited) response handle.
fn awaitSpinning(fib: Fiber, frame: int) -> int = match fiberDone(fib) {
    1 => await(fib)
    _ => spinFrame(fib: fib, frame: frame)
}
fn spinFrame(fib: Fiber, frame: int) -> int = {
    print(loaderFrame(frame))
    sleep(60)
    awaitSpinning(fib: fib, frame: inc(frame))
}

fn fetchBody(path: string) -> Result<string, Error> =
    collect(clientId: httpCreateClient("https://api.github.com", 10000), path: path, headers: ghHeaders())

fn fetchRawBody(path: string) -> Result<string, Error> =
    collect(clientId: httpCreateClient("https://api.github.com", 10000), path: path, headers: rawHeaders())

fn collect(clientId: int, path: string, headers: string) -> Result<string, Error> =
    finish(clientId: clientId,
           resp: awaitSpinning(fib: spawn rawGet(clientId: clientId, path: path, headers: headers), frame: 0))

fn finish(clientId: int, resp: int) -> Result<string, Error> = match resp > 0 {
    true  => closeAfter(clientId: clientId, result: freeAfter(value: resp, result: httpResponseBody(resp)))
    false => closeAfter(clientId: clientId, result: Error { message: "request failed" })
}

fn freeAfter(value: int, result: Result<string, Error>) -> Result<string, Error> = {
    httpResponseFree(value)
    result
}

fn closeAfter(clientId: int, result: Result<string, Error>) -> Result<string, Error> = {
    httpCloseClient(clientId)
    result
}

// `main` installs the handlers that discharge each effect into real I/O, then
// runs the pure effect logic underneath them.
fn main() -> Unit =
    handle Console
        print line => print(line)
    in handle Terminal
        readKey => termReadKey()
        raw on => termRawMode(on)
    in handle Http
        fetch path => fetchBody(path)
        fetchRaw path => fetchRawBody(path)
    in {
        app()
    }
